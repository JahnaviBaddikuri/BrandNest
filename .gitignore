# ========================
# BrandNest - Root .gitignore
# ========================

# Visual Studio
.vs/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Environment files
.env
.env.local
.env.*.local

# Firebase credentials (NEVER commit!)
firebase-credentials.json
*-firebase-adminsdk-*.json

# Database files
*.db
*.sqlite
*.sqlite3

# Python
__pycache__/
*.py[cod]
*.so
venv/
env/
.venv/

# Node
node_modules/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Temporary
tmp/
temp/
*.tmp
*.bak
